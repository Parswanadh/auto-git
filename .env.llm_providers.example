# ============================================
# LLM PROVIDERS (Dual-Mode System)
# ============================================
# Add these variables to your .env file

# GLM-4.5 (Z.ai or ZhipuAI) - Primary Cloud Provider
# Z.ai: https://z.ai (OpenAI-compatible API)
# ZhipuAI: https://open.bigmodel.cn/ (Official SDK)
GLM_API_KEY=your_glm_api_key_here

# GLM API Provider: 'z.ai' or 'zhipuai' (default: z.ai)
GLM_API_PROVIDER=z.ai

# GLM Model (Z.ai): glm-4.7, glm-4.6, glm-4.5, glm-4.5-air
# GLM Model (ZhipuAI): glm-4-plus, glm-4-0520, glm-4-air
GLM_MODEL=glm-4.7

# Anthropic Claude - Optional (Best for code review)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# CLAUDE_MODEL=claude-3-5-sonnet-20241022

# OpenAI GPT-4 - Optional
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o

# ============================================
# EXECUTION MODE
# ============================================

# LLM Execution Mode (optional - will prompt if not set)
# Options: local | cloud | parallel | fallback
# LLM_EXECUTION_MODE=fallback

# ============================================
# NOVELTY DETECTION
# ============================================

# Novelty threshold for detecting novel projects (0.0-1.0)
NOVELTY_THRESHOLD=0.6

# ============================================
# COST CONTROLS
# ============================================

# Daily spending limit for cloud APIs (USD)
LLM_DAILY_COST_LIMIT=10.0

# ============================================
# LOCAL OLLAMA CONFIGURATION
# ============================================

# Ollama server URL
OLLAMA_BASE_URL=http://localhost:11434
